# MBG Clicker — environment variables
# Copy this file to `.env.local` and fill in the values.
# Get the Supabase values from: https://supabase.com/dashboard → your project → Settings → API

# Public (exposed to the browser) — anon key, safe to ship client-side
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — service role key. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Secret token used to protect the cron endpoint (/api/cron/*).
# Use any long random string, e.g. `openssl rand -hex 32`.
CRON_SECRET=
